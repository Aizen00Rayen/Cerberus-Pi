# Cerberus Pi — environment template
# Copy to /opt/cerberus/secrets/.env and chmod 600. Values marked AUTO are
# generated by cerberus_install.sh; do NOT commit a filled-in copy.

# --- Django ---
DJANGO_SECRET_KEY=AUTO                 # 64-char urandom hex, generated at install
DJANGO_DEBUG=0
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
# Management interface address the dashboard is allowed on (wlan0). Set at install.
CERBERUS_MGMT_HOST=127.0.0.1

# --- PostgreSQL (Unix socket only — no host/port on a network interface) ---
POSTGRES_DB=cerberus
POSTGRES_USER=cerberus
POSTGRES_PASSWORD=AUTO                 # generated at install
# Socket dir, not a TCP host. psycopg2 uses HOST as the socket directory path.
POSTGRES_HOST=/var/run/postgresql
POSTGRES_PORT=

# --- Redis (localhost only) ---
REDIS_URL=redis://127.0.0.1:6379/0
CELERY_BROKER_URL=redis://127.0.0.1:6379/1
CELERY_RESULT_BACKEND=redis://127.0.0.1:6379/2

# --- IPFS (private node, local API only) ---
IPFS_API=/ip4/127.0.0.1/tcp/5001
IPFS_LOG_RETENTION_DAYS=90

# --- Network / engines ---
MONITOR_IFACE=eth0
MGMT_IFACE=wlan0
SSH_PORT=2242

# --- Threat intelligence (optional) ---
NVD_API_KEY=                           # https://nvd.nist.gov/developers/request-an-api-key
# Optional LLM advice enhancement. Leave blank to use rule-based advice only.
LLM_PROVIDER=                          # one of: "", openai, ollama
OPENAI_API_KEY=
OLLAMA_HOST=http://127.0.0.1:11434

# --- Report / scan retention ---
SCAN_RETENTION_DAYS=90
