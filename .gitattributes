# Cerberus Pi runs on Linux (Raspberry Pi). Force LF on everything that the Pi
# executes or parses, regardless of the contributor's OS / git autocrlf setting.
# CRLF in a shell script breaks the shebang on Linux ("bad interpreter").

*               text=auto eol=lf
*.sh            text eol=lf
*.py            text eol=lf
*.lua           text eol=lf
*.yaml          text eol=lf
*.yml           text eol=lf
*.conf          text eol=lf
*.rules         text eol=lf
*.service       text eol=lf
*.target        text eol=lf
*.mount         text eol=lf
*.env           text eol=lf
.env.example    text eol=lf
sudoers.d-cerberus text eol=lf
Makefile        text eol=lf

# Web assets — keep LF for consistency.
*.js            text eol=lf
*.jsx           text eol=lf
*.css           text eol=lf
*.html          text eol=lf
*.json          text eol=lf
*.md            text eol=lf

# Binary — never normalise.
*.png           binary
*.jpg           binary
*.pdf           binary
*.gz            binary
