# Cerberus Pi — Snort 3 local rules (Phase 3.2)
# Installed to /opt/cerberus/snort/rules/local.rules. Loaded alongside the
# community ruleset. Add site-specific detections here.
#
# SIDs in the 1,000,000+ range are reserved for local rules by convention.

# ICMP ping sweep detection (recon precursor).
alert icmp $EXTERNAL_NET any -> $HOME_NET any ( msg:"CERBERUS Recon ICMP ping sweep"; itype:8; detection_filter:track by_src, count 10, seconds 5; classtype:attempted-recon; sid:1000001; rev:1; )

# SSH brute force (many connection attempts to port 22).
alert tcp $EXTERNAL_NET any -> $HOME_NET 22 ( msg:"CERBERUS Brute Force SSH connection flood"; flow:to_server; detection_filter:track by_src, count 8, seconds 30; classtype:attempted-admin; sid:1000002; rev:1; )

# Outbound connection to common C2 ports from an internal host.
alert tcp $HOME_NET any -> $EXTERNAL_NET [4444,1337,31337,8443] ( msg:"CERBERUS Possible Malware C2 outbound"; flow:to_server,established; classtype:trojan-activity; sid:1000003; rev:1; )

# Large DNS TXT responses (possible DNS tunneling/exfil).
alert udp $HOME_NET any -> $EXTERNAL_NET 53 ( msg:"CERBERUS DNS Tunneling suspicious query volume"; detection_filter:track by_src, count 100, seconds 10; classtype:policy-violation; sid:1000004; rev:1; )
