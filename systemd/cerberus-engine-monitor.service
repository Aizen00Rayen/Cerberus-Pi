[Unit]
Description=Cerberus Pi — engine watchdog (Phase 3.3)
After=cerberus-ids.target cerberus-backend.service redis-server.service
Wants=cerberus-ids.target

[Service]
Type=simple
User=cerberus
Group=cerberus
WorkingDirectory=/opt/cerberus
EnvironmentFile=/opt/cerberus/secrets/.env
ExecStart=/opt/cerberus/venv/bin/python /opt/cerberus/scripts/engine_monitor.py
Restart=always
RestartSec=10
NoNewPrivileges=yes
ReadWritePaths=/opt/cerberus/logs

[Install]
WantedBy=multi-user.target
